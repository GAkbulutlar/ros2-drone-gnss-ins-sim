<?xml version="1.0"?>
<robot name="my_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:arg name="controllers_config" default="" />

    <xacro:property name="base_length" value="0.6" />
    <xacro:property name="base_width" value="0.4" />
    <xacro:property name="base_height" value="0.2" />
    <xacro:property name="wheel_radius" value="0.1" />
    <xacro:property name="wheel_length" value="0.05" />

    <xacro:macro name="box_inertia" params="m x y z o_xyz o_rpy">
        <inertial>
            <mass value="${m}" />
            <origin xyz="${o_xyz}" rpy="${o_rpy}" />
            <inertia ixx="${(m/12.0) * (y*y + z*z)}" ixy="0" ixz="0"
                     iyy="${(m/12.0) * (x*x + z*z)}" iyz="0"
                     izz="${(m/12.0) * (x*x + y*y)}" />
        </inertial>
    </xacro:macro> 

    <xacro:macro name="cylinder_inertia" params="m r h o_xyz o_rpy">
        <inertial>
            <mass value="${m}" />
            <origin xyz="${o_xyz}" rpy="${o_rpy}" />
            <inertia ixx="${(m/12.0) * (3*r*r + h*h)}" ixy="0" ixz="0"
                     iyy="${(m/12.0) * (3*r*r + h*h)}" iyz="0"
                     izz="${(m/2.0) * r*r}" />
        </inertial>
    </xacro:macro>

    <material name="green">
        <color rgba="0 0.5 0 1" />
    </material>

    <material name="blue">
        <color rgba="0 0 0.5 1" />
    </material>

    <material name="red">
        <color rgba="0.8 0 0 1" />
    </material>

    <link name="base_footprint" />

    <link name="base_link">
        <visual>
            <geometry>
                <box size="${base_length} ${base_width} ${base_height}" />
            </geometry>
            <origin xyz="0.0 0.0 ${base_height / 2.0}" rpy="0 0 0" />
            <material name="green" />
        </visual>
        <collision>
            <geometry>
                <box size="${base_length} ${base_width} ${base_height}" />
            </geometry>
            <origin xyz="0.0 0.0 ${base_height / 2.0}" rpy="0 0 0" />
        </collision>

        <xacro:box_inertia m="5" x="${base_length}" y="${base_width}" z="${base_height}" o_xyz="0 0 ${base_height / 2.0}" o_rpy="0 0 0" />
    </link>

    <joint name="base_footprint_joint" type="fixed">
        <parent link="base_footprint" />
        <child link="base_link" />
        <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0" />
    </joint>

    <xacro:macro name="wheel" params="prefix x_reflect y_reflect">
        <link name="${prefix}_wheel_link">
            <visual>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_length}" />
                </geometry>
                <origin xyz="0 0 0" rpy="1.5708 0 0" />
                <material name="blue" />
            </visual>

            <collision>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_length}" />
                </geometry>
                <origin xyz="0.0 0.0 0" rpy="1.5708 0 0" />
            </collision>

            <xacro:cylinder_inertia m="1" r="${wheel_radius}" h="${wheel_length}" o_xyz="0 0 0" o_rpy="1.5708 0 0" />
        </link>

        <joint name="base_${prefix}_wheel_joint" type="continuous">
            <parent link="base_link" />
            <child link="${prefix}_wheel_link" />
            <origin xyz="${x_reflect * (base_length / 4.0)} ${y_reflect * 0.225} 0" rpy="0 0 0" />
            <axis xyz="0 1 0" />
        </joint>
    </xacro:macro>

    <xacro:wheel prefix="front_right" x_reflect="1"  y_reflect="-1" />
    <xacro:wheel prefix="front_left"  x_reflect="1"  y_reflect="1" />
    <xacro:wheel prefix="rear_right"  x_reflect="-1" y_reflect="-1" />
    <xacro:wheel prefix="rear_left"   x_reflect="-1" y_reflect="1" />

    <!-- ==========================================
         ros2_control hardware interfaces
    ========================================== -->
    <ros2_control name="GazeboSystem" type="system">
        <hardware>
            <plugin>gz_ros2_control/GazeboSimSystem</plugin>
        </hardware>
        <joint name="base_front_left_wheel_joint">
            <command_interface name="velocity"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="base_front_right_wheel_joint">
            <command_interface name="velocity"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="base_rear_left_wheel_joint">
            <command_interface name="velocity"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <joint name="base_rear_right_wheel_joint">
            <command_interface name="velocity"/>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        <!-- IMU sensor state interfaces: lets gz_ros2_control manage the sensor
             and publish it via imu_sensor_broadcaster instead of Gazebo bridge -->
        <sensor name="imu_sensor">
            <state_interface name="orientation.x"/>
            <state_interface name="orientation.y"/>
            <state_interface name="orientation.z"/>
            <state_interface name="orientation.w"/>
            <state_interface name="angular_velocity.x"/>
            <state_interface name="angular_velocity.y"/>
            <state_interface name="angular_velocity.z"/>
            <state_interface name="linear_acceleration.x"/>
            <state_interface name="linear_acceleration.y"/>
            <state_interface name="linear_acceleration.z"/>
        </sensor>
    </ros2_control>

    <!-- gz_ros2_control plugin (starts controller_manager inside Gazebo) -->
    <gazebo>
        <plugin filename="gz_ros2_control-system"
                name="gz_ros2_control::GazeboSimROS2ControlPlugin">
            <parameters>$(arg controllers_config)</parameters>
        </plugin>
    </gazebo>

    <!-- Ground truth odometry from Gazebo model pose -->
    <gazebo>
        <plugin filename="gz-sim-odometry-publisher-system"
                name="gz::sim::systems::OdometryPublisher">
            <odom_frame>odom</odom_frame>
            <robot_base_frame>base_footprint</robot_base_frame>
            <odom_topic>/model/my_robot/ground_truth/odom</odom_topic>
            <tf_topic>/model/my_robot/ground_truth/tf</tf_topic>
            <odom_publish_frequency>50</odom_publish_frequency>
        </plugin>
    </gazebo>

    <!-- Ground truth raw pose (position + orientation only, no velocity) -->
    <gazebo>
        <plugin filename="gz-sim-pose-publisher-system"
                name="gz::sim::systems::PosePublisher">
            <topic>/model/my_robot/pose_gt</topic>
            <publish_link_pose>false</publish_link_pose>
            <publish_visual_pose>false</publish_visual_pose>
            <publish_collision_pose>false</publish_collision_pose>
            <publish_sensor_pose>false</publish_sensor_pose>
            <use_pose_vector_msg>false</use_pose_vector_msg>
            <publish_model_pose>true</publish_model_pose>
            <publish_nested_model_pose>true</publish_nested_model_pose>
        </plugin>
    </gazebo>
    
    <xacro:property name="camera_length" value="0.01" />
    <xacro:property name="camera_width" value="0.1" />
    <xacro:property name="camera_height" value="0.05" />

    <link name="camera_link">
        <visual>
            <geometry>
                <box size="${camera_length} ${camera_width} ${camera_height}" />
            </geometry>
            <material name="blue" />
        </visual>
        <collision>
            <geometry>
                <box size="${camera_length} ${camera_width} ${camera_height}" />
            </geometry>
        </collision>
        <xacro:box_inertia m="0.1" x="${camera_length}" y="${camera_width}" z="${camera_height}" o_xyz="0 0 0" o_rpy="0 0 0" />
    </link>

    <joint name="base_camera_joint" type="fixed">
        <parent link="base_link" />
        <child link="camera_link" />
        <origin xyz="${base_length / 2.0} 0 ${base_height + camera_height / 2.0}" rpy="0 0 0" />
    </joint>

    <link name="camera_link_optical" />

    <joint name="camera_optical_joint" type="fixed">
        <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}" />
            <parent link="camera_link" />
            <child link="camera_link_optical" />
    </joint>

    <gazebo reference="camera_link">
        <sensor name="camera" type="camera">
            <camera>
                <horizontal_fov>1.3962634</horizontal_fov>
                <image>
                    <width>640</width>
                    <height>480</height>
                    <format>R8G8B8</format>
                </image>
                <clip>
                    <near>0.1</near>
                    <far> 15 </far>
                </clip>
                <noise>
                    <type> gaussian </type>
                    <mean> 0.0 </mean>
                    <stddev>0.007 </stddev>
                </noise>
                <optical_frame_id>camera_link_optical</optical_frame_id>
                <camera_info_topic>camera/camera_info</camera_info_topic>
            </camera>
            <always_on>1</always_on>
            <visualize>true</visualize>
            <update_rate>20</update_rate>
            <topic>camera/image_raw</topic>
        </sensor>
    </gazebo>

    <xacro:property name="laser_radius" value="0.05" />
    <xacro:property name="laser_height" value="0.04" />

    <link name="laser_frame">
        <visual>
            <geometry>
                <cylinder radius="${laser_radius}" length="${laser_height}" />
            </geometry>
            <material name="red" />
        </visual>
        <collision>
            <geometry>
                <cylinder radius="${laser_radius}" length="${laser_height}" />
            </geometry>
        </collision>
        <xacro:cylinder_inertia m="0.1" r="${laser_radius}" h="${laser_height}" o_xyz="0 0 0" o_rpy="0 0 0" />
    </link>

    <joint name="base_laser_joint" type="fixed">
        <parent link="base_link" />
        <child link="laser_frame" />
        <origin xyz="0.0 0.0 ${base_height + laser_height / 2.0}" rpy="0 0 0" />
    </joint>

   <gazebo reference="laser_frame">
        <sensor name="lidar" type="lidar">
            <pose>0 0 0 0 0 0</pose>
            <always_on>1</always_on>
            <visualize>true</visualize>
            <update_rate>10</update_rate>
            <topic>scan</topic>
            <lidar>
                <scan>
                    <horizontal>
                        <samples>640</samples>
                        <resolution>1</resolution>
                        <min_angle>-3.1415926</min_angle> 
                        <max_angle>3.1415926</max_angle>  
                    </horizontal>
                </scan>
                <range>
                    <min>0.08</min>
                    <max>10.0</max>
                </range>
                <noise>
                    <type>gaussian</type>
                    <mean>0.0</mean>
                    <stddev>0.01</stddev>
                </noise>
            </lidar>
            
            <gz_frame_id>laser_frame</gz_frame_id>
            
            <frame_id>laser_frame</frame_id>
        </sensor>
    </gazebo>

    <!-- ==========================================
         IMU SENSOR
    ========================================== -->
    <link name="imu_link">
        <visual>
            <geometry>
                <box size="0.05 0.05 0.02" />
            </geometry>
            <material name="red" />
        </visual>
        <collision>
            <geometry>
                <box size="0.05 0.05 0.02" />
            </geometry>
        </collision>
        <xacro:box_inertia m="0.05" x="0.05" y="0.05" z="0.02"
                           o_xyz="0 0 0" o_rpy="0 0 0" />
    </link>

    <joint name="base_imu_joint" type="fixed">
        <parent link="base_link" />
        <child link="imu_link" />
        <origin xyz="0 0 ${base_height}" rpy="0 0 0" />
    </joint>

    <gazebo reference="imu_link">
        <sensor name="imu_sensor" type="imu">
            <always_on>1</always_on>
            <update_rate>100</update_rate>
            <visualize>false</visualize>
            <topic>imu</topic>
            <gz_frame_id>imu_link</gz_frame_id>
            <imu>
                <!-- Noise: budget consumer MEMS level - produces visible deviation -->
                <angular_velocity>
                    <x><noise type="gaussian">
                        <mean>0.0</mean><stddev>0.009</stddev>
                        <bias_mean>0.03</bias_mean><bias_stddev>0.005</bias_stddev>
                    </noise></x>
                    <y><noise type="gaussian">
                        <mean>0.0</mean><stddev>0.009</stddev>
                        <bias_mean>0.03</bias_mean><bias_stddev>0.005</bias_stddev>
                    </noise></y>
                    <z><noise type="gaussian">
                        <mean>0.0</mean><stddev>0.009</stddev>
                        <bias_mean>0.03</bias_mean><bias_stddev>0.005</bias_stddev>
                    </noise></z>
                </angular_velocity>
                <linear_acceleration>
                    <x><noise type="gaussian">
                        <mean>0.0</mean><stddev>0.065</stddev>
                        <bias_mean>0.18</bias_mean><bias_stddev>0.015</bias_stddev>
                    </noise></x>
                    <y><noise type="gaussian">
                        <mean>0.0</mean><stddev>0.065</stddev>
                        <bias_mean>0.18</bias_mean><bias_stddev>0.015</bias_stddev>
                    </noise></y>
                    <z><noise type="gaussian">
                        <mean>0.0</mean><stddev>0.065</stddev>
                        <bias_mean>0.18</bias_mean><bias_stddev>0.015</bias_stddev>
                    </noise></z>
                </linear_acceleration>
            </imu>
        </sensor>
    </gazebo>
</robot>